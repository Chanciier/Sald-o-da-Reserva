# ═══════════════════════════════════════════════════════════════════════════════
# SALDÃO DA RESERVA — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copie este arquivo para .env e preencha os valores conforme o ambiente:
#   cp .env.example .env
#
# Dev:          valores locais (localhost, TEST-tokens, sandbox=true)
# Homologação:  serviços reais em modo sandbox/teste, URLs públicas temporárias
# Produção:     credenciais reais, MELHOR_ENVIO_SANDBOX=false, NODE_ENV=production
# ═══════════════════════════════════════════════════════════════════════════════


# ── Ambiente ──────────────────────────────────────────────────────────────────
# dev | production
NODE_ENV=development


# ── PostgreSQL (Docker Compose local) ─────────────────────────────────────────
# Usado pelo docker-compose.yml para subir o container do banco.
# Em homologação/produção, use DATABASE_URL direto (sem estas vars).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=saldao_db
POSTGRES_PORT=5432

# ── Redis (Docker Compose local) ──────────────────────────────────────────────
REDIS_PORT=6379


# ── API (NestJS) ──────────────────────────────────────────────────────────────
API_PORT=3001

# Porta usada pelo Nest (PORT sobrescreve API_PORT em plataformas como Railway/Render)
PORT=3001

# Cadeia de conexão completa com o banco
# Dev:         postgresql://postgres:postgres@localhost:5432/saldao_db
# Homologação: postgresql://USER:PASS@HOST:5432/saldao_db?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saldao_db

# Cadeia de conexão com Redis
# Dev:         redis://localhost:6379
# Homologação: redis://default:PASS@HOST:PORT
REDIS_URL=redis://localhost:6379


# ── JWT ───────────────────────────────────────────────────────────────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret_here
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret_here


# ── URLs ──────────────────────────────────────────────────────────────────────
# Dev:         http://localhost:3000
# Homologação: https://seu-projeto.vercel.app,https://preview.vercel.app
#              (separar múltiplas origens por vírgula para CORS)
FRONTEND_URL=http://localhost:3000

# URL pública da API (usada em webhooks, e-mails, etc.)
# Dev:         http://localhost:3001
# Homologação: https://api.seu-dominio-teste.com
API_PUBLIC_URL=http://localhost:3001


# ── Web (Next.js) ─────────────────────────────────────────────────────────────
WEB_PORT=3000

# URL da API acessada pelo browser (NEXT_PUBLIC_ é exposto ao cliente)
# Dev:         http://localhost:3001
# Homologação: https://api.seu-dominio-teste.com
NEXT_PUBLIC_API_URL=http://localhost:3001


# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# "skip" bypassa verificação (dev/testes)
# Em homologação use as chaves de teste do Cloudflare:
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=skip
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA


# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Credenciais em: https://www.mercadopago.com.br/settings/account/credentials
#
# Dev/Homologação: token começa com TEST-
# Produção:        token começa com APP_USR-
#
# NUNCA use credenciais de produção em homologação.
MERCADO_PAGO_ACCESS_TOKEN=TEST-REPLACE_ME
MERCADO_PAGO_WEBHOOK_SECRET=REPLACE_ME

# Chave pública (SDK frontend, apps/web/.env.local)
# Dev/Homologação: TEST-xxxx...
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-REPLACE_ME


# ── Amazon S3 ─────────────────────────────────────────────────────────────────
# Para dev local com MinIO: adicione AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_BUCKET_NAME=saldaoreserva-img
# CDN_URL=https://cdn.seudominio.com    (opcional — CloudFront)
# AWS_ENDPOINT_URL=http://localhost:9000 (MinIO local)


# ── Melhor Envio ──────────────────────────────────────────────────────────────
# Token em: https://melhorenvio.com.br/configuracoes/tokens
MELHOR_ENVIO_TOKEN=REPLACE_ME
# Dev/Homologação: true  |  Produção: false
MELHOR_ENVIO_SANDBOX=true
MELHOR_ENVIO_WEBHOOK_TOKEN=

# Endereço de origem (remetente)
MELHOR_ENVIO_FROM_NAME=Nome da Empresa
MELHOR_ENVIO_FROM_EMAIL=email@empresa.com
MELHOR_ENVIO_FROM_DOCUMENT=00.000.000/0001-00
MELHOR_ENVIO_FROM_PHONE=11900000000
MELHOR_ENVIO_FROM_CEP=00000-000
MELHOR_ENVIO_FROM_ADDRESS=Rua Exemplo
MELHOR_ENVIO_FROM_NUMBER=100
MELHOR_ENVIO_FROM_COMPLEMENT=
MELHOR_ENVIO_FROM_DISTRICT=Bairro
MELHOR_ENVIO_FROM_CITY=Cidade
MELHOR_ENVIO_FROM_STATE=SP


# ── Focus NFe ─────────────────────────────────────────────────────────────────
# Token em: https://focusnfe.com.br
# Dev/Homologação: sandbox  |  Produção: production
FOCUS_NFE_TOKEN=REPLACE_ME
FOCUS_NFE_ENVIRONMENT=sandbox

# Dados do emitente
FOCUS_NFE_CNPJ=00000000000000
FOCUS_NFE_IE=123456789012
FOCUS_NFE_RAZAO_SOCIAL=Saldão da Reserva Ltda
FOCUS_NFE_NOME_FANTASIA=Saldão da Reserva
FOCUS_NFE_LOGRADOURO=Rua Exemplo
FOCUS_NFE_NUMERO=100
FOCUS_NFE_BAIRRO=Centro
FOCUS_NFE_MUNICIPIO=São Paulo
FOCUS_NFE_UF=SP
FOCUS_NFE_CEP=01310100
# CRT: 1=Simples Nacional  2=Simples Nacional excesso  3=Regime Normal
FOCUS_NFE_CRT=1


# ── Resend (e-mail transacional) ──────────────────────────────────────────────
# Chave em: https://resend.com/api-keys
# Se vazio, os e-mails são apenas logados no console (sem erro).
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@seudominio.com.br
