# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=saldao_db
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=3001
NODE_ENV=development

# JWT — use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret_here
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret_here

# Cloudflare Turnstile — set to "skip" for development
TURNSTILE_SECRET_KEY=skip

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001

# Mercado Pago (backend)
MERCADO_PAGO_ACCESS_TOKEN=TEST-REPLACE_ME
MERCADO_PAGO_WEBHOOK_SECRET=REPLACE_ME

# Mercado Pago (frontend — apps/web/.env.local)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-REPLACE_ME
