NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saldao_db

# Redis
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=http://localhost:3000

# JWT — use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret_here
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret_here

# Cloudflare Turnstile
# Set to "skip" to bypass verification in development
TURNSTILE_SECRET_KEY=skip

# ── Stripe ────────────────────────────────────────────────────────────────────
#
# DEVELOPMENT:  Get test keys at https://dashboard.stripe.com/test/apikeys
#               Keys starting with sk_test_ / pk_test_ are safe for development.
# PRODUCTION:   Use live keys (sk_live_ / pk_live_) only in the production env.
#
# STRIPE_SECRET_KEY   — Backend secret; never expose to the frontend.
# STRIPE_PUBLISHABLE_KEY — Frontend public key; set in apps/web/.env.local as
#                          NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

#
# STRIPE_WEBHOOK_SECRET — Signs incoming webhook events so we can verify
#                         they really came from Stripe.
#
# DEVELOPMENT (local):
#   1. Install Stripe CLI: https://stripe.com/docs/stripe-cli
#   2. Run:  stripe listen --forward-to localhost:3001/api/v1/payments/webhook
#   3. Copy the webhook signing secret printed in the terminal (whsec_...) here.
#   Events forwarded: payment_intent.succeeded, payment_intent.payment_failed,
#                     payment_intent.canceled, charge.succeeded, charge.failed
#
# PRODUCTION:
#   1. In Stripe Dashboard → Developers → Webhooks → Add endpoint
#      URL: https://yourdomain.com/api/v1/payments/webhook
#   2. Select events: payment_intent.succeeded, payment_intent.payment_failed,
#                     payment_intent.canceled, charge.succeeded, charge.failed
#   3. Copy the Signing secret (whsec_...) here.
#
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Melhor Envio ──────────────────────────────────────────────────────────────
MELHOR_ENVIO_TOKEN=REPLACE_ME
MELHOR_ENVIO_SANDBOX=true

# ── eNotas ────────────────────────────────────────────────────────────────────
ENOTAS_API_KEY=REPLACE_ME
ENOTAS_COMPANY_ID=REPLACE_ME
ENOTAS_ENVIRONMENT=sandbox

# ── Amazon S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1
AWS_BUCKET_NAME=saldao-produtos

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@seudominio.com.br
