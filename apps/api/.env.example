NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saldao_db

# Redis
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=http://localhost:3000

# JWT — use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret_here
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret_here

# Cloudflare Turnstile
# Set to "skip" to bypass verification in development
TURNSTILE_SECRET_KEY=skip

# ── Mercado Pago ──────────────────────────────────────────────────────────────
#
# Obtenha as credenciais em: https://www.mercadopago.com.br/settings/account/credentials
#
# MERCADO_PAGO_ACCESS_TOKEN — Token de acesso do backend (nunca exponha ao frontend).
#   Sandbox:    TEST-xxxx...
#   Produção:   APP_USR-xxxx...
#
MERCADO_PAGO_ACCESS_TOKEN=TEST-REPLACE_ME

#
# MERCADO_PAGO_WEBHOOK_SECRET — Segredo para validar notificações do Mercado Pago.
#   Configure o webhook em: https://www.mercadopago.com.br/developers/panel/webhooks
#   URL: https://seudominio.com/api/v1/payments/webhook
#
MERCADO_PAGO_WEBHOOK_SECRET=REPLACE_ME

# URL pública da API (usada no notification_url do Mercado Pago)
# Em produção: https://api.seudominio.com
API_PUBLIC_URL=http://localhost:3001

# Web Push (gere com: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@seudominio.com.br

# ── Amazon S3 ─────────────────────────────────────────────────────────────────
# Para dev local com MinIO: adicione AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_BUCKET_NAME=saldaoreserva-img
# CDN_URL=https://cdn.seudominio.com  (opcional, CloudFront)
# AWS_ENDPOINT_URL=http://localhost:9000  (MinIO local)

# ── Melhor Envio ──────────────────────────────────────────────────────────────
# Obtenha o token em: https://melhorenvio.com.br/configuracoes/tokens
MELHOR_ENVIO_TOKEN=REPLACE_ME
# Use "false" em produção
MELHOR_ENVIO_SANDBOX=true
# Token enviado pelo ME nos webhooks (defina ao registrar o webhook)
MELHOR_ENVIO_WEBHOOK_TOKEN=

# Endereço de origem (remetente)
MELHOR_ENVIO_FROM_NAME=Nome da Empresa
MELHOR_ENVIO_FROM_EMAIL=email@empresa.com
MELHOR_ENVIO_FROM_DOCUMENT=00.000.000/0001-00
MELHOR_ENVIO_FROM_PHONE=11900000000
MELHOR_ENVIO_FROM_CEP=00000-000
MELHOR_ENVIO_FROM_ADDRESS=Rua Exemplo
MELHOR_ENVIO_FROM_NUMBER=100
MELHOR_ENVIO_FROM_COMPLEMENT=
MELHOR_ENVIO_FROM_DISTRICT=Bairro
MELHOR_ENVIO_FROM_CITY=Cidade
MELHOR_ENVIO_FROM_STATE=SP

# (Opcional) Restringe quais transportadoras/serviços aparecem na cotação.
# Vazio = mostra TODAS as opções da conta (comportamento padrão).
# MELHOR_ENVIO_ALLOWED_CARRIERS — nomes (substring, case-insensitive), por vírgula.
#   Ex.: "Loggi" — única que faz COLETA na origem (as demais exigem drop-off
#   em agência/ponto). Útil quando não há como levar o pacote a uma agência.
# MELHOR_ENVIO_ALLOWED_SERVICES — IDs de serviço (têm prioridade sobre CARRIERS).
#   IDs reais da conta: Correios PAC=1 / SEDEX=2, Jadlog .Package=3,
#   Loggi Express=31 / Coleta=32. Ex.: "32" para oferecer só Loggi Coleta.
MELHOR_ENVIO_ALLOWED_CARRIERS=
MELHOR_ENVIO_ALLOWED_SERVICES=

# ── Focus NFe ─────────────────────────────────────────────────────────────────
# Obtenha o token em: https://focusnfe.com.br
# FOCUS_NFE_ENVIRONMENT: "production" ou "sandbox" (homologação)
FOCUS_NFE_TOKEN=REPLACE_ME
FOCUS_NFE_ENVIRONMENT=sandbox

# Dados do emitente (empresa)
FOCUS_NFE_CNPJ=00000000000000
FOCUS_NFE_IE=123456789012
FOCUS_NFE_RAZAO_SOCIAL=Saldão da Reversa Ltda
FOCUS_NFE_NOME_FANTASIA=Saldão da Reversa
FOCUS_NFE_LOGRADOURO=Rua Exemplo
FOCUS_NFE_NUMERO=100
FOCUS_NFE_BAIRRO=Centro
FOCUS_NFE_MUNICIPIO=São Paulo
FOCUS_NFE_UF=SP
FOCUS_NFE_CEP=01310100
# CRT: 1=Simples Nacional  2=Simples Nacional - excesso  3=Regime Normal
FOCUS_NFE_CRT=1

# Webhook URL para notificações Focus NFe:
# https://seudominio.com/api/v1/invoices/webhook/focusnfe

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@seudominio.com.br
