generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DRAFT
  ARCHIVED
  // OMS: ciclo de vida para produtos únicos e proteção contra venda duplicada.
  RESERVED
  SOLD
  UNAVAILABLE
  REMOVED
}

// ── OMS / Marketplace ─────────────────────────────────────────────────────────
enum Marketplace {
  SITE
  MERCADO_LIVRE
  SHOPEE
}

enum PublicationStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  PAUSED
  REMOVED
  SYNC_PENDING
}

enum SyncAction {
  PUBLISH
  UPDATE
  UPDATE_STOCK
  UPDATE_PRICE
  PAUSE
  REMOVE
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum WebhookSource {
  MERCADO_PAGO
  MERCADO_LIVRE
  SHOPEE
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum CouponType {
  PERCENT
  FIXED
}

enum DeliveryMethod {
  SHIPPING
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SEPARATING
  SEPARATED
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  LABEL_PURCHASED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
}

enum PaymentStatus {
  PENDING
  APPROVED
  AUTHORIZED
  IN_PROCESS
  IN_MEDIATION
  REJECTED
  CANCELLED
  REFUNDED
  CHARGED_BACK
}

enum InvoiceStatus {
  PENDING
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
}

enum ReturnReason {
  REGRET
  DEFECT
  WRONG_ITEM
  OTHER
}

enum ReturnStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

// ── Analytics de comportamento (funil, tráfego, engajamento) ──────────────────
enum AnalyticsEventType {
  PAGE_VIEW
  PRODUCT_VIEW
  PRODUCT_CLICK
  ADD_TO_CART
  REMOVE_FROM_CART
  CHECKOUT_START
  PURCHASE
  SEARCH
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  cpf          String?  @map("cpf")
  phone        String?  @map("phone")
  avatarUrl    String?  @map("avatar_url")
  passwordHash String   @map("password_hash")
  role         Role     @default(CLIENTE)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]
  auditLogs       AuditLog[]
  images          Image[]
  orders          Order[]
  products        Product[]
  returnRequests  ReturnRequest[]
  consents        UserConsent[]
  reviews         Review[]
  notifications   Notification[]
  pushSubscriptions PushSubscription[]
  recoveryCoupons Coupon[] @relation("RecoveryCouponOwner")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ncm         String?
  showOnHome  Boolean  @default(false) @map("show_on_home")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]
  images   Image[]

  @@map("categories")
}

model Product {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  sku                 String        @unique
  internalCode        String?       @map("internal_code") @db.VarChar(100)
  brand               String?
  shortDescription    String?       @map("short_description") @db.Text
  description         String?
  price               Decimal       @db.Decimal(10, 2)
  salePrice           Decimal?      @map("sale_price") @db.Decimal(10, 2)
  weight              Decimal?      @db.Decimal(8, 3)
  dimensions          Json?
  stock               Int           @default(0)
  minimumStock        Int           @default(0) @map("minimum_stock")
  // OMS: produto único (peça de saldão sem reposição). Reserva estoque já no
  // pedido e pausa o anúncio nos demais canais para evitar venda duplicada.
  isUnique            Boolean       @default(false) @map("is_unique")
  ncm                 String?
  origem              Int?          @default(0)
  cfop                String?       @db.VarChar(10)
  cstCsosn            String?       @map("cst_csosn") @db.VarChar(10)
  // OMS/Marketplace: dados usados na publicação em marketplaces externos (ML).
  // `gtin` (EAN/UPC) é exigido por várias categorias do Mercado Livre; `condition`
  // mapeia para o campo `condition` do anúncio ('new' | 'used').
  gtin                String?
  condition           String        @default("new")
  pickupAvailable     Boolean       @default(false) @map("pickup_available")
  featuredOffer       Boolean       @default(false) @map("featured_offer")
  status              ProductStatus @default(ACTIVE)
  metaTitle           String?       @map("meta_title") @db.VarChar(200)
  metaDescription     String?       @map("meta_description") @db.VarChar(500)
  autoPublishWhatsapp Boolean       @default(false) @map("auto_publish_whatsapp")
  whatsappGroupIds    String[]      @default([]) @map("whatsapp_group_ids")
  categoryId          String?       @map("category_id")
  createdById         String?       @map("created_by")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy    User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  images       Image[]
  orderItems   OrderItem[]
  reviews      Review[]
  whatsappLogs    WhatsappMessageLog[]
  whatsappContent WhatsappContentHistory[]
  metaCatalogSync MetaCatalogSync?
  publications    MarketplacePublication[]
  syncLogs        MarketplaceSyncLog[]
  notifications   Notification[]
  analyticsEvents AnalyticsEvent[]

  @@index([categoryId])
  @@index([status])
  @@index([createdById])
  @@index([isUnique])
  @@map("products")
}

model WhatsappGroup {
  id        String   @id @default(cuid())
  name      String
  groupId   String   @unique @map("group_id")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs WhatsappMessageLog[]

  @@map("whatsapp_groups")
}

model WhatsappMessageLog {
  id        String        @id @default(cuid())
  productId String        @map("product_id")
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String        @map("group_id")
  group     WhatsappGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  success   Boolean
  error     String?
  sentAt    DateTime      @default(now()) @map("sent_at")

  @@index([productId])
  @@index([groupId])
  @@map("whatsapp_message_logs")
}

model WhatsappContentHistory {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  content   String
  edited    Boolean  @default(false)
  sent      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("whatsapp_content_history")
}

model Image {
  id         String   @id @default(cuid())
  url        String
  key        String   @unique
  bucket     String
  folder     String
  size       Int
  mimeType   String   @map("mime_type")
  width      Int?
  height     Int?
  position   Int      @default(0)
  productId  String?  @map("product_id")
  categoryId String?  @map("category_id")
  userId     String?  @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  product  Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([categoryId])
  @@index([userId])
  @@map("images")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?  @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  description   String?
  type          CouponType
  value         Decimal    @db.Decimal(10, 2)
  minOrderValue Decimal?   @map("min_order_value") @db.Decimal(10, 2)
  maxDiscount   Decimal?   @map("max_discount") @db.Decimal(10, 2)
  usageLimit    Int?       @map("usage_limit")
  usageCount    Int        @default(0) @map("usage_count")
  isActive      Boolean    @default(true) @map("is_active")
  expiresAt     DateTime?  @map("expires_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  ownerUserId   String?    @map("owner_user_id")
  sourceOrderId String?    @unique @map("source_order_id")

  orders      Order[] @relation("AppliedCoupon")
  owner       User?   @relation("RecoveryCouponOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceOrder Order?  @relation("RecoveryCouponSource", fields: [sourceOrderId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([sourceOrderId])
  @@map("coupons")
}

model Order {
  id              String      @id @default(cuid())
  userId          String      @map("user_id")
  couponId        String?     @map("coupon_id")
  status          OrderStatus    @default(PENDING)
  deliveryMethod  DeliveryMethod @default(SHIPPING) @map("delivery_method")
  // OMS: canal de origem do pedido. SITE = loja própria; demais = marketplaces.
  // `externalId` é o id do pedido no marketplace (idempotência de importação);
  // `externalReference` guarda o pack/shipment usado para agrupar/rastrear.
  channel           Marketplace @default(SITE)
  externalId        String?     @map("external_id")
  externalReference String?     @map("external_reference")
  subtotal        Decimal        @db.Decimal(10, 2)
  discount        Decimal        @default(0) @db.Decimal(10, 2)
  shipping        Decimal        @default(0) @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)
  shippingAddress Json?          @map("shipping_address")
  shippingMethod  String         @map("shipping_method")
  notes           String?
  buyerName       String?  @map("buyer_name")
  customerPhone   String?  @map("customer_phone")
  pickupCode      String?  @unique @map("pickup_code")
  separatedItems  Json?    @map("separated_items")
  separationNotes String?  @map("separation_notes")
  pickupRemindedAt DateTime? @map("pickup_reminded_at")
  stockApplied    Boolean  @default(false) @map("stock_applied")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  cartReminderCreatedAt DateTime? @map("cart_reminder_created_at")
  cartReminderPushSentAt DateTime? @map("cart_reminder_push_sent_at")
  recoveryCouponCreatedAt DateTime? @map("recovery_coupon_created_at")
  recoveryCouponPushSentAt DateTime? @map("recovery_coupon_push_sent_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon         Coupon?          @relation("AppliedCoupon", fields: [couponId], references: [id], onDelete: SetNull)
  recoveryCoupon Coupon?          @relation("RecoveryCouponSource")
  items          OrderItem[]
  payment        Payment?
  shipment       Shipment?
  invoices       Invoice[]
  returnRequests ReturnRequest[]
  statusEvents   OrderStatusEvent[]
  notifications  Notification[]

  @@unique([channel, externalId], map: "orders_channel_external_id_key")
  @@index([userId])
  @@index([channel])
  @@index([status, channel, createdAt])
  @@map("orders")
}

// Linha do tempo de alto nível do pedido (estados visíveis ao cliente/admin).
// Diferente de ShipmentEvent (eventos da transportadora) — aqui registramos cada
// transição do pedido com título legível e quem executou.
model OrderStatusEvent {
  id          String      @id @default(cuid())
  orderId     String      @map("order_id")
  status      OrderStatus
  title       String
  description String?
  actor       String?
  createdAt   DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_events")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  name      String
  sku       String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @unique @map("order_id")
  gatewayPaymentId String?       @unique @map("gateway_payment_id")
  clientSecret     String?       @map("client_secret") @db.Text
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  amount           Decimal       @db.Decimal(10, 2)
  idempotencyKey   String        @unique @map("idempotency_key")
  pixQrCode        String?       @map("pix_qr_code") @db.Text
  pixQrCodeBase64  String?       @map("pix_qr_code_base64") @db.Text
  pixExpiresAt     DateTime?     @map("pix_expires_at")
  boletoUrl        String?       @map("boleto_url")
  boletoCode       String?       @map("boleto_code") @db.Text
  boletoExpiresAt  DateTime?     @map("boleto_expires_at")
  cardBrand        String?       @map("card_brand")
  cardLast4        String?       @map("card_last_4")
  installments     Int?
  rawStatus        String?       @map("raw_status")
  statusDetail     String?       @map("status_detail")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  logs  PaymentLog[]

  @@index([gatewayPaymentId])
  @@map("payments")
}

model Notification {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  roleTarget Role      @map("role_target")
  type       String
  title      String
  message    String
  orderId    String?   @map("order_id")
  productId  String?   @map("product_id")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  order   Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, type, orderId])
  @@index([userId, readAt, createdAt])
  @@index([roleTarget, createdAt])
  @@index([productId])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Shipment {
  id           String         @id @default(cuid())
  orderId      String         @unique @map("order_id")
  meOrderId    String?        @unique @map("me_order_id")
  frenetTicket String?        @unique @map("frenet_ticket")
  // Id do envio no marketplace de origem (ex.: shipment do Mercado Livre). Usado
  // para baixar a etiqueta e sincronizar o rastreio quando o canal não é o ME.
  externalId   String?        @map("external_id")
  carrier      String
  service      String
  serviceId    Int            @map("service_id")
  serviceCode  String?        @map("service_code")
  trackingCode String?        @map("tracking_code")
  status       ShipmentStatus @default(PENDING)
  labelUrl     String?        @map("label_url") @db.Text
  price        Decimal        @db.Decimal(10, 2)
  deliveryMin  Int?           @map("delivery_min")
  deliveryMax  Int?           @map("delivery_max")
  rawQuote     Json?          @map("raw_quote")
  rawData      Json?          @map("raw_data")
  shippedAt    DateTime?      @map("shipped_at")
  deliveredAt  DateTime?      @map("delivered_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@map("shipments")
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String   @map("shipment_id")
  event       String
  status      String?
  description String?
  location    String?
  rawData     Json?    @map("raw_data")
  createdAt   DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_events")
}

model PaymentLog {
  id        String   @id @default(cuid())
  paymentId String   @map("payment_id")
  event     String
  status    String?
  rawData   Json?    @map("raw_data")
  createdAt DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_logs")
}

model Invoice {
  id               String        @id @default(cuid())
  orderId          String        @map("order_id")
  focusReference   String?       @unique @map("focus_reference")
  invoiceNumber    String?       @map("invoice_number")
  accessKey        String?       @map("access_key") @db.VarChar(60)
  protocol         String?       @map("protocol") @db.VarChar(30)
  status           InvoiceStatus @default(PENDING)
  xmlUrl           String?       @map("xml_url") @db.Text
  danfeUrl         String?       @map("danfe_url") @db.Text
  issueDate        DateTime?     @map("issue_date")
  cancellationDate DateTime?     @map("cancellation_date")
  errorMessage     String?       @map("error_message") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([focusReference])
  @@index([status])
  @@map("invoices")
}

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  published Boolean  @default(false)
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("legal_pages")
}

model Faq {
  id        String   @id @default(cuid())
  category  String
  question  String
  answer    String   @db.Text
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model UserConsent {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  type            String
  documentVersion Int      @default(1) @map("document_version")
  ipAddress       String?  @map("ip_address")
  acceptedAt      DateTime @default(now()) @map("accepted_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_consents")
}

model ReturnRequest {
  id                String       @id @default(cuid())
  orderId           String       @map("order_id")
  userId            String       @map("user_id")
  reason            ReturnReason
  notes             String?      @db.Text
  status            ReturnStatus @default(PENDING)
  adminNotes        String?      @map("admin_notes") @db.Text
  meOrderId         String?      @unique @map("me_order_id")
  trackingCode      String?      @map("tracking_code")
  labelUrl          String?      @map("label_url") @db.Text
  postedAt          DateTime?    @map("posted_at")
  returnDeliveredAt DateTime?    @map("return_delivered_at")
  refundId          String?      @map("refund_id")
  refundAmount      Decimal?     @map("refund_amount") @db.Decimal(10, 2)
  refundStatus      String?      @map("refund_status")
  refundedAt        DateTime?    @map("refunded_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("return_requests")
}

model Review {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

model MetaCatalogSync {
  id           String    @id @default(cuid())
  productId    String    @unique @map("product_id")
  status       String    @default("PENDING")
  errorMessage String?   @map("error_message") @db.Text
  syncedAt     DateTime? @map("synced_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("meta_catalog_syncs")
}

// ── OMS / Marketplace ─────────────────────────────────────────────────────────

// Estado de publicação de um produto em cada marketplace. Um par
// (product, marketplace) é único: representa "onde o produto está anunciado".
model MarketplacePublication {
  id               String            @id @default(cuid())
  productId        String            @map("product_id")
  marketplace      Marketplace
  externalId       String?           @map("external_id")
  status           PublicationStatus @default(PENDING)
  errorMessage     String?           @map("error_message") @db.Text
  payloadSent      Json?             @map("payload_sent")
  responseReceived Json?             @map("response_received")
  publishedAt      DateTime?         @map("published_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace])
  @@index([marketplace, status])
  @@index([status])
  @@map("marketplace_publications")
}

// Log de cada operação de sincronização disparada para um marketplace.
model MarketplaceSyncLog {
  id           String      @id @default(cuid())
  productId    String      @map("product_id")
  marketplace  Marketplace
  action       SyncAction
  status       SyncStatus  @default(PENDING)
  errorMessage String?     @map("error_message") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")
  finishedAt   DateTime?   @map("finished_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([marketplace, status])
  @@index([createdAt])
  @@map("marketplace_sync_logs")
}

// Log bruto de todo webhook recebido (MP, ML, Shopee). Persistido antes de
// qualquer processamento para nunca travar o fluxo principal e permitir replay.
model WebhookLog {
  id           String        @id @default(cuid())
  source       WebhookSource
  eventType    String?       @map("event_type")
  payload      Json
  status       WebhookStatus @default(RECEIVED)
  errorMessage String?       @map("error_message") @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")
  processedAt  DateTime?     @map("processed_at")

  @@index([source, status])
  @@index([createdAt])
  @@map("webhook_logs")
}

// Sessão de navegação anônima (id gerado no cliente). `visitorId` persiste em
// localStorage entre sessões e permite distinguir visitantes novos/recorrentes.
model AnalyticsSession {
  id              String      @id
  visitorId       String      @map("visitor_id")
  startedAt       DateTime    @default(now()) @map("started_at")
  lastSeenAt      DateTime    @default(now()) @updatedAt @map("last_seen_at")
  durationSeconds Int         @default(0) @map("duration_seconds")
  pageViews       Int         @default(0) @map("page_views")
  device          DeviceType?
  browser         String?
  os              String?
  referrer        String?     @db.VarChar(500)
  utmSource       String?     @map("utm_source")
  utmMedium       String?     @map("utm_medium")
  utmCampaign     String?     @map("utm_campaign")
  landingPath     String?     @map("landing_path") @db.VarChar(500)
  exitPath        String?     @map("exit_path") @db.VarChar(500)
  converted       Boolean     @default(false)

  events AnalyticsEvent[]

  @@index([startedAt])
  @@index([visitorId])
  @@map("analytics_sessions")
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  sessionId String             @map("session_id")
  type      AnalyticsEventType
  path      String?            @db.VarChar(500)
  productId String?            @map("product_id")
  metadata  Json?
  createdAt DateTime           @default(now()) @map("created_at")

  session AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([type, createdAt])
  @@index([productId])
  @@index([createdAt])
  @@map("analytics_events")
}
