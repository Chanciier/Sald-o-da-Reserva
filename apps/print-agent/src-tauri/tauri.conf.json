{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Saldão Print Agent",
  "version": "0.1.0",
  "identifier": "com.saldaodareserva.printagent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Saldão Print Agent",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": ["resources/SumatraPDF.exe"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      },
      "wix": {
        "language": "pt-BR"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
