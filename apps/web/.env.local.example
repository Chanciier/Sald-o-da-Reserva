# ── Next.js — Variáveis de ambiente do frontend ───────────────────────────────
# Copie para .env.local e preencha conforme o ambiente.
#
# Dev:         http://localhost:3001
# Homologação: https://api.seu-dominio-teste.com
# Produção:    https://api.seudominio.com.br
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mercado Pago — chave pública (SDK frontend)
# Dev/Homologação: TEST-xxxx...
# Produção:        APP_USR-xxxx...
# Obtenha em: https://www.mercadopago.com.br/settings/account/credentials
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-REPLACE_ME

# Cloudflare Turnstile — chave pública do site
# Dev/Homologação: 1x00000000000000000000AA (chave de teste oficial)
# Produção:        chave real do seu site em dash.cloudflare.com
# Deixe em branco para desabilitar no frontend (backend usa TURNSTILE_SECRET_KEY=skip)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
