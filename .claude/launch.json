{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/web"],
      "port": 3000
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:dev", "--prefix", "apps/api"],
      "port": 3001,
      "env": {
        "DATABASE_URL": "postgresql://postgres:postgres@127.0.0.1:5432/saldao_db",
        "REDIS_URL": "redis://127.0.0.1:6379",
        "TURNSTILE_SECRET_KEY": "skip",
        "FRONTEND_URL": "http://localhost:3000"
      }
    }
  ]
}
